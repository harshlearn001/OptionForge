# ============================================================
# OptionForge
# .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------
# Python Version
# ------------------------------------------------------------
.python-version

# ------------------------------------------------------------
# IDE / Editors
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Test / Coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ------------------------------------------------------------
# Type Checking / Linting
# ------------------------------------------------------------
.mypy_cache/
.pytype/
.ruff_cache/

# ------------------------------------------------------------
# Build / Packaging
# ------------------------------------------------------------
build/
dist/
site/
*.egg-info/
.eggs/
*.egg
*.whl
pip-wheel-metadata/

# ------------------------------------------------------------
# PyInstaller
# ------------------------------------------------------------
*.spec

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------
*.tmp
*.temp
*.bak

# ------------------------------------------------------------
# Output Files
# ------------------------------------------------------------
output/

# Keep folder structure
!output/.gitkeep

# ------------------------------------------------------------
# Data Files
# ------------------------------------------------------------
data/

# Keep folder structure
!data/.gitkeep
!data/future/.gitkeep
!data/greeks/.gitkeep
!data/option/.gitkeep
!data/riskfree/.gitkeep
!data/spot/.gitkeep

# ------------------------------------------------------------
# Parquet Files
# ------------------------------------------------------------
*.parquet

# ------------------------------------------------------------
# CSV Files
# ------------------------------------------------------------
*.csv

# Keep sample/example CSVs
!sample.csv
!examples/*.csv

# ------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------
.env
.env.*
.envrc

# ------------------------------------------------------------
# Local Configuration
# ------------------------------------------------------------
config.local.py
settings.local.py

# ------------------------------------------------------------
# Documentation Build
# ------------------------------------------------------------
docs/_build/

# ------------------------------------------------------------
# Profiling
# ------------------------------------------------------------
.prof
*.prof

# ------------------------------------------------------------
# Runtime
# ------------------------------------------------------------
*.pid

# ------------------------------------------------------------
# Package Manager
# ------------------------------------------------------------
poetry.lock
Pipfile.lock

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
.cache/
.cache-loader/