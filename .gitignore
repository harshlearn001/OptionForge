# ============================================================
# OptionForge
# .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------
# IDE
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# OS Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Test / Coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ------------------------------------------------------------
# Build
# ------------------------------------------------------------
build/
dist/
*.egg-info/

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log

# ------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------
*.tmp
*.bak
*.swp

# ------------------------------------------------------------
# Output Files
# ------------------------------------------------------------
output/

# Keep folder structure
!output/.gitkeep

# ------------------------------------------------------------
# Data Files
# ------------------------------------------------------------
data/

# Keep folder structure
!data/.gitkeep
!data/future/.gitkeep
!data/greeks/.gitkeep
!data/option/.gitkeep
!data/riskfree/.gitkeep
!data/spot/.gitkeep

# ------------------------------------------------------------
# Parquet
# ------------------------------------------------------------
*.parquet

# ------------------------------------------------------------
# CSV Files
# ------------------------------------------------------------
*.csv

# Keep example/sample CSVs
!examples/*.csv
!sample.csv

# ------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------
.env
.env.*

# ------------------------------------------------------------
# Local Configuration
# ------------------------------------------------------------
config.local.py